{
  "name": "kodi-dev",
  "version": "0.1.1",
  "description": "kodi.dev — Claude Code-native agent orchestrator CLI",
  "license": "MIT",
  "author": "Luis Soares",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luis0ares/kodi-dev.git"
  },
  "homepage": "https://github.com/luis0ares/kodi-dev#readme",
  "bugs": "https://github.com/luis0ares/kodi-dev/issues",
  "packageManager": "pnpm@11.5.0",
  "keywords": [
    "claude-code",
    "agents",
    "orchestrator",
    "cli",
    "tickets",
    "pull-request"
  ],
  "type": "module",
  "bin": {
    "kodi": "dist/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "commander": "^12.1.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
